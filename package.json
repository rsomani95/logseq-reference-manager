{
  "name": "logseq-zoterolocal-plugin",
  "author": "benjypng",
  "description": "Connect to Zotero locally using Zotero Beta 7 (and above), import and keep track of your Zotero library.",
  "license": "MIT",
  "logseq": {
    "id": "logseq-zoterolocal-plugin",
    "title": "logseq-zoterolocal-plugin",
    "icon": "./icon.svg",
    "main": "dist/index.html"
  },
  "scripts": {
    "dev": "bunx vite",
    "build": "bunx vite build",
    "test": "bun test",
    "prepare": "husky",
    "lint:precommit": "echo \"Running biome\" && bunx biome check . --write && echo \"Running tsc\" && bunx tsc --noEmit"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/github",
        {
          "assets": [
            "logseq-zoterolocal-plugin.zip"
          ],
          "options": {
            "successComment": false
          }
        }
      ]
    ]
  },
  "dependencies": {
    "@logseq/libs": "^0.2.9",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.554.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.66.1",
    "wretch": "^3.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@types/bun": "^1.3.13",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "postcss": "^8.5.6",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-logseq": "^1.1.2",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
