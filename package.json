{
  "name": "logseq-reference-manager",
  "version": "0.1.0",
  "author": "Rahul Somani",
  "description": "Reference manager for importing from Zotero locally and from the Web clipper",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rsomani95/logseq-reference-manager.git"
  },
  "homepage": "https://github.com/rsomani95/logseq-reference-manager#readme",
  "bugs": {
    "url": "https://github.com/rsomani95/logseq-reference-manager/issues"
  },
  "keywords": [
    "logseq",
    "logseq-plugin",
    "zotero",
    "references",
    "citations",
    "bibliography",
    "pkm"
  ],
  "logseq": {
    "id": "logseq-reference-manager",
    "title": "Reference Manager",
    "icon": "./icon.svg",
    "main": "dist/index.html"
  },
  "scripts": {
    "dev": "bunx vite",
    "build": "bunx vite build",
    "test": "bun test",
    "prepare": "husky",
    "lint:precommit": "echo \"Running biome\" && bunx biome check . --write && echo \"Running tsc\" && bunx tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@logseq/libs": "0.3.3",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.554.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.66.1",
    "wretch": "^3.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@types/bun": "^1.3.13",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "postcss": "^8.5.6",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-logseq": "^1.1.2",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
